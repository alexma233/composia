controller:
  listen_addr: ":7001"
  controller_addr: "http://controller-dev:7001"
  repo_dir: "/data/repo-controller"
  state_dir: "/data/state-controller"
  log_dir: "/data/logs"
  access_tokens:
    - name: "dev-admin"
      token: "replace-with-dev-controller-token"
      enabled: true
  nodes:
    - id: "main"
      display_name: "Main"
      enabled: true
      token: "replace-with-dev-main-agent-token"
  rustic:
    main_nodes:
      - "main"
  secrets:
    provider: age
    identity_file: "/workspace/dev/age-identity.key"
    recipient_file: "/workspace/dev/age-recipients.txt"
    armor: true

agent:
  controller_addr: "http://controller-dev:7001"
  node_id: "main"
  token: "replace-with-dev-main-agent-token"
  repo_dir: "/data/repo-agent"
  state_dir: "/data/state-agent"
