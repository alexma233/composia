{
  "name": "composia",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "web:dev": "bun run --cwd web dev",
    "web:build": "bun run --cwd web build",
    "web:check:bundle": "bun run --cwd web check:bundle",
    "web:preview": "bun run --cwd web preview",
    "web:check": "bun run --cwd web check",
    "web:test": "bun run --cwd web test",
    "web:e2e": "bun run --cwd web e2e",
    "cli:e2e": "go test -tags=e2e ./test/e2e",
    "controller:e2e": "go test -tags=e2e ./test/controller_e2e",
    "web:format": "bun run --cwd web format",
    "web:format:write": "bun run --cwd web format:write",
    "docs:api:generate": "sh ./scripts/docs/generate-proto-docs.sh",
    "docs:dev": "hugo serve --port 5174 -s site",
    "docs:build": "hugo --minify -s site"
  }
}
