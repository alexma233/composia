{
  "name": "@composia/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "check:bundle": "deno task build && deno run --allow-read scripts/check-bundle-budget.ts",
    "preview": "vite preview",
    "test": "deno test --no-check src/lib/*.test.mjs src/lib/server/*.test.mjs",
    "e2e": "playwright test",
    "check": "svelte-kit sync && svelte-check --fail-on-warnings --tsconfig ./tsconfig.json",
    "check:a11y": "svelte-kit sync && svelte-check --fail-on-warnings --tsconfig ./tsconfig.json",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@bufbuild/protoc-gen-es": "2.12.1",
    "@playwright/test": "1.61.1",
    "@sveltejs/kit": "2.69.2",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.1",
    "bits-ui": "2.18.1",
    "mode-watcher": "1.1.0",
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1",
    "shadcn-svelte": "1.4.1",
    "svelte": "5.56.4",
    "svelte-check": "4.7.2",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.3.2",
    "tslib": "2.8.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.1.4"
  },
  "dependencies": {
    "@deno/svelte-adapter": "0.2.1",
    "@bufbuild/protobuf": "2.12.1",
    "@codemirror/commands": "6.10.4",
    "@codemirror/language": "6.12.4",
    "@codemirror/language-data": "6.5.2",
    "@codemirror/lint": "6.9.7",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@connectrpc/connect": "2.1.2",
    "@connectrpc/connect-node": "2.1.2",
    "@fsegurai/codemirror-theme-github-dark": "6.2.5",
    "@fsegurai/codemirror-theme-github-light": "6.2.5",
    "@hyperjump/json-pointer": "1.1.2",
    "@lezer/common": "1.5.2",
    "@lezer/highlight": "1.2.3",
    "@lezer/lr": "1.4.10",
    "@wterm/dom": "0.3.0",
    "@wterm/ghostty": "0.3.0",
    "ajv": "8.20.0",
    "clsx": "2.1.1",
    "codemirror": "6.0.2",
    "dequal": "2.0.3",
    "envfile": "7.1.0",
    "@lucide/svelte": "1.23.0",
    "svelte-sonner": "1.1.1",
    "tailwind-merge": "3.6.0",
    "valibot": "1.4.2",
    "vscode-material-icons": "0.1.1",
    "yaml": "2.9.0"
  }
