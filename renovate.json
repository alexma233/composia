{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "dependencyDashboard": true,
  "separateMajorMinor": true,
  "rangeStrategy": "pin",
  "lockFileMaintenance": {
    "enabled": true
  },
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch",
        "pin"
      ],
      "groupName": "web non-major dependencies"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch"
      ],
      "groupName": "go non-major dependencies"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchDepTypes": [
        "indirect"
      ],
      "enabled": true,
      "groupName": "go indirect dependencies"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "pinDigests": true
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "forgejo.alexma.top/alexma233/ci-images"
      ],
      "versioning": "regex:^(?<compatibility>.+)-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "git-refs"
      ],
      "groupName": "forgejo action digest updates"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "github.com/pseudomuto/protoc-gen-doc"
      ],
      "groupName": "docs tool updates"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "forgejo.alexma.top/alexma233/ci-images",
        "forgejo.alexma.top/alexma233/ci-images-go-node",
        "github.com/air-verse/air"
      ],
      "groupName": "tooling updates"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts\\/docs\\/generate-proto-docs\\.sh$/"
      ],
      "matchStrings": [
        "github\\.com/pseudomuto/protoc-gen-doc/cmd/protoc-gen-doc@(?<currentValue>v?[0-9][^\\s\"']*)"
      ],
      "depNameTemplate": "github.com/pseudomuto/protoc-gen-doc",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.forgejo\\/workflows\\/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "\\s*# renovate: datasource=(?<datasource>git-refs) depName=(?<depName>[^\\s]+) packageName=(?<packageName>[^\\s]+) currentValue=(?<currentValue>[^\\s]+)\\n\\s*uses:\\s+https://forgejo\\.alexma\\.top/[^@\\s]+@(?<currentDigest>[a-f0-9]{40})"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.forgejo\\/workflows\\/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "\\s*container:\\s*\\n\\s*image:\\s+(?<depName>forgejo\\.alexma\\.top\\/alexma233\\\/(?:ci-images|ci-images-go-node)):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "go install\\s+(?<depName>github\\.com\\/air-verse\\/air)@(?<currentValue>v?[^\\s\"']+)"
      ],
      "datasourceTemplate": "go"
    }
  ]
}
