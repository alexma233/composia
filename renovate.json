{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "dependencyDashboard": true,
  "separateMajorMinor": true,
  "rangeStrategy": "pin",
  "lockFileMaintenance": {
    "enabled": true
  },
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch",
        "pin"
      ],
      "groupName": "web non-major dependencies"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch"
      ],
      "groupName": "go non-major dependencies"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchDepTypes": [
        "indirect"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch"
      ],
      "enabled": true,
      "groupName": "go indirect non-major dependencies"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "pinDigests": true
    },
    {
      "matchPackageNames": [
        "deno",
        "denoland/deno"
      ],
      "groupName": "deno runtime updates"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "git-refs"
      ],
      "groupName": "forgejo action digest updates"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "github.com/pseudomuto/protoc-gen-doc"
      ],
      "groupName": "docs tool updates"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "forgejo.alexma.top/alexma233/ci-images-deno",
        "forgejo-registry-raw.alexma.top/alexma233/ci-images-go-node-docker-deno-chromium",
        "forgejo.alexma.top/alexma233/ci-images-go-node-docker",
        "forgejo.alexma.top/alexma233/ci-images-go-node-docs",
        "forgejo.alexma.top/alexma233/ci-images-go-node-lint",
        "forgejo.alexma.top/alexma233/ci-images-hugo-wrangler",
        "forgejo.alexma.top/alexma233/ci-images-go-node",
        "forgejo.alexma.top/alexma233/ci-images-go-releaser"
      ],
      "groupName": "tooling updates"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "github.com/air-verse/air"
      ],
      "groupName": "tooling updates"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^mise\\.toml$/"
      ],
      "matchStrings": [
        "deno\\s*=\\s*\\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "depNameTemplate": "deno",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "denoland/deno",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts\\/docs\\/generate-proto-docs\\.sh$/"
      ],
      "matchStrings": [
        "github\\.com/pseudomuto/protoc-gen-doc/cmd/protoc-gen-doc@(?<currentValue>v?[0-9][^\\s\"']*)"
      ],
      "depNameTemplate": "github.com/pseudomuto/protoc-gen-doc",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.forgejo\\/workflows\\/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "\\s*# renovate: datasource=(?<datasource>git-refs) depName=(?<depName>[^\\s]+) packageName=(?<packageName>[^\\s]+) currentValue=(?<currentValue>[^\\s]+)\\n\\s*uses:\\s+https://forgejo\\.alexma\\.top/[^@\\s]+@(?<currentDigest>[a-f0-9]{40})"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "go install\\s+(?<depName>github\\.com\\/air-verse\\/air)@(?<currentValue>v?[^\\s\"']+)"
      ],
      "datasourceTemplate": "go"
    }
  ]
}
